# Image references
HEX_CORE_IMAGE=rg.fr-par.scw.cloud/ce-rise-software/hex-core-service:latest
DP_STORAGE_IMAGE=rg.fr-par.scw.cloud/ce-rise-software/dp-storage-jsondb:v0.0.1
POSTGRES_IMAGE=docker.io/library/postgres:17
NGINX_IMAGE=docker.io/library/nginx:1.27-alpine
DEMO_RUNNER_IMAGE=dp-demo-runner:local

# Public exposure
HEX_CORE_PORT=8080
DP_STORAGE_PORT=8081
ARTIFACT_SERVER_PORT=8082
POSTGRES_PORT=5432

# Core runtime
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_REQUEST_MAX_BYTES=1048576
LOG_LEVEL=info
METRICS_ENABLED=false

# Core registry
REGISTRY_MODE=catalog
REGISTRY_CATALOG_FILE=/config/registry/catalog.json
REGISTRY_ALLOWED_HOSTS=artifact-server
REGISTRY_REQUIRE_HTTPS=false
REGISTRY_CACHE_ENABLED=false
REGISTRY_CACHE_TTL_SECS=300

# Core adapter
IO_ADAPTER_ID=http
IO_ADAPTER_VERSION=v1
IO_ADAPTER_BASE_URL=http://dp-storage-jsondb-service:8080
IO_ADAPTER_TIMEOUT_MS=5000

# Core auth
AUTH_MODE=none
AUTH_ALLOW_INSECURE_NONE=true
AUTH_NONE_SUBJECT=demo-user
AUTH_NONE_ROLES=demo
AUTH_NONE_SCOPES=records:read records:write

# Backend runtime
DP_STORAGE_SERVER_HOST=0.0.0.0
DP_STORAGE_SERVER_PORT=8080
DB_BACKEND=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=dp_storage
DB_USER=dp_storage
DB_PASSWORD=dp_storage_demo
DB_POOL_SIZE=10
DB_TIMEOUT_MS=5000
DP_STORAGE_AUTH_MODE=disabled

# Demo flow
DEMO_MODEL=dp-record-metadata
DEMO_VERSION=0.0.2
DEMO_BASE_URL=http://hex-core-service:8080
